{
  "name": "docmind",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:browser": "vite --host 127.0.0.1 --port 5173 --open",
    "tauri:dev": "DOCMIND_USE_PY_PARSER=1 DOCMIND_FASTEMBED_CACHE_DIR=\"$PWD/.docmind-cache/fastembed\" tauri dev",
    "tauri:dev:trace": "DOCMIND_USE_PY_PARSER=1 DOCMIND_FASTEMBED_CACHE_DIR=\"$PWD/.docmind-cache/fastembed\" DOCMIND_TRACE_INDEXER=1 tauri dev",
    "tauri:dev:fresh": "DOCMIND_USE_PY_PARSER=1 DOCMIND_FASTEMBED_CACHE_DIR=\"$PWD/.docmind-cache/fastembed\" tauri dev -- --reset-local-storage",
    "tauri:dev:fresh:trace": "DOCMIND_USE_PY_PARSER=1 DOCMIND_FASTEMBED_CACHE_DIR=\"$PWD/.docmind-cache/fastembed\" DOCMIND_TRACE_INDEXER=1 tauri dev -- --reset-local-storage",
    "semantic:warmup": "DOCMIND_FASTEMBED_CACHE_DIR=\"$PWD/.docmind-cache/fastembed\" python3 parser/docmind_parser/__main__.py warmup-embedding BAAI/bge-small-zh-v1.5",
    "semantic:warmup:mirror": "DOCMIND_FASTEMBED_CACHE_DIR=\"$PWD/.docmind-cache/fastembed\" HF_ENDPOINT=https://hf-mirror.com python3 parser/docmind_parser/__main__.py warmup-embedding BAAI/bge-small-zh-v1.5",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  }
}

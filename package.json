{
  "name": "seek-mind",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:browser": "vite --host 127.0.0.1 --port 5173 --open",
    "tauri:dev": "SEEKMIND_USE_PY_PARSER=1 SEEKMIND_PARSER_SCRIPT=\"$PWD/parser/seekmind_parser/__main__.py\" SEEKMIND_FASTEMBED_CACHE_DIR=\"$PWD/.SeekMind-cache/fastembed\" tauri dev",
    "tauri:dev:debug": "SEEKMIND_USE_PY_PARSER=1 SEEKMIND_PARSER_SCRIPT=\"$PWD/parser/seekmind_parser/__main__.py\" SEEKMIND_FASTEMBED_CACHE_DIR=\"$PWD/.SeekMind-cache/fastembed\" SEEKMIND_OPEN_DEVTOOLS=1 tauri dev",
    "tauri:dev:trace": "SEEKMIND_USE_PY_PARSER=1 SEEKMIND_PARSER_SCRIPT=\"$PWD/parser/seekmind_parser/__main__.py\" SEEKMIND_FASTEMBED_CACHE_DIR=\"$PWD/.SeekMind-cache/fastembed\" SEEKMIND_TRACE_INDEXER=1 tauri dev",
    "tauri:dev:fresh": "SEEKMIND_USE_PY_PARSER=1 SEEKMIND_PARSER_SCRIPT=\"$PWD/parser/seekmind_parser/__main__.py\" SEEKMIND_FASTEMBED_CACHE_DIR=\"$PWD/.SeekMind-cache/fastembed\" tauri dev -- --reset-local-storage",
    "tauri:dev:fresh:trace": "SEEKMIND_USE_PY_PARSER=1 SEEKMIND_PARSER_SCRIPT=\"$PWD/parser/seekmind_parser/__main__.py\" SEEKMIND_FASTEMBED_CACHE_DIR=\"$PWD/.SeekMind-cache/fastembed\" SEEKMIND_TRACE_INDEXER=1 tauri dev -- --reset-local-storage",
    "tauri:dev:first-launch": "SEEKMIND_USE_PY_PARSER=1 SEEKMIND_PARSER_SCRIPT=\"$PWD/parser/seekmind_parser/__main__.py\" SEEKMIND_FASTEMBED_CACHE_DIR=\"$PWD/.SeekMind-cache/fastembed\" SEEKMIND_FORCE_FIRST_LAUNCH=1 tauri dev",
    "tauri:build:macos:adhoc": "APPLE_SIGNING_IDENTITY=- tauri build",
    "tauri:build:macos:sidecar": "bash scripts/build-parser-sidecar.sh && APPLE_SIGNING_IDENTITY=- tauri build",
    "semantic:warmup": "SEEKMIND_FASTEMBED_CACHE_DIR=\"$PWD/.SeekMind-cache/fastembed\" SEEKMIND_PARSER_SCRIPT=\"$PWD/parser/seekmind_parser/__main__.py\" python3 parser/seekmind_parser/__main__.py warmup-embedding BAAI/bge-small-zh-v1.5",
    "semantic:warmup:mirror": "SEEKMIND_FASTEMBED_CACHE_DIR=\"$PWD/.SeekMind-cache/fastembed\" SEEKMIND_PARSER_SCRIPT=\"$PWD/parser/seekmind_parser/__main__.py\" HF_ENDPOINT=https://hf-mirror.com python3 parser/seekmind_parser/__main__.py warmup-embedding BAAI/bge-small-zh-v1.5",
    "benchmark:baseline": "cargo run --manifest-path src-tauri/Cargo.toml --bin seekmind-benchmark --",
    "benchmark:stress": "cargo run --manifest-path src-tauri/Cargo.toml --bin seekmind-stress --",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "dompurify": "^3.4.5",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.2.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^6.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.6.2",
    "vite": "^7.0.0",
    "vue-tsc": "^2.1.10"
  }
}

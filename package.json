{
  "name": "seek-mind",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:browser": "vite --host 127.0.0.1 --port 5173 --open",
    "check:frontend": "npm run build",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "check:all": "npm run check:frontend && npm run check:rust",
    "tauri:dev": "node scripts/tauri-dev.mjs",
    "tauri:dev:debug": "node scripts/tauri-dev.mjs --devtools",
    "tauri:dev:trace": "node scripts/tauri-dev.mjs --trace-indexer",
    "tauri:dev:fresh": "node scripts/tauri-dev.mjs --reset-local-storage",
    "tauri:dev:fresh:trace": "node scripts/tauri-dev.mjs --trace-indexer --reset-local-storage",
    "tauri:dev:first-launch": "node scripts/tauri-dev.mjs --first-launch",
    "tauri:build:macos:adhoc": "node scripts/tauri-build.mjs --apple-adhoc",
    "build:parser-sidecar": "node scripts/build-parser-sidecar.mjs",
    "tauri:build:macos:sidecar": "node scripts/build-parser-sidecar.mjs --tauri-build --apple-adhoc",
    "tauri:build:windows": "node scripts/build-parser-sidecar.mjs --tauri-build --target x86_64-pc-windows-msvc",
    "tauri:build:windows:sidecar": "node scripts/build-parser-sidecar.mjs --tauri-build --target x86_64-pc-windows-msvc",
    "semantic:warmup": "node scripts/semantic-warmup.mjs",
    "semantic:warmup:mirror": "node scripts/semantic-warmup.mjs --mirror",
    "benchmark:baseline": "cargo run --manifest-path src-tauri/Cargo.toml --bin seekmind-benchmark --",
    "benchmark:stress": "cargo run --manifest-path src-tauri/Cargo.toml --bin seekmind-stress --",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "dompurify": "^3.4.5",
    "lucide-vue-next": "^1.0.0",
    "markdown-it": "^14.2.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^6.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.6.2",
    "vite": "^7.0.0",
    "vue-tsc": "^2.1.10"
  }
}
